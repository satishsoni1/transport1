# Backend Configuration
NODE_ENV=development
PORT=3001

# Local PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/trimurti_tms
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=trimurti_tms
PGSSLMODE=disable

# Default admin user created during db bootstrap
ADMIN_EMAIL=admin@trimurti.com
ADMIN_PASSWORD=admin123
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_ROLE=Admin

# JWT Secret (change in production)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: Sentry for error tracking
SENTRY_DSN=
